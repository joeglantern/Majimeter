# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Dashboard → your project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Dashboard → Settings → Database → Connection string → URI (port 5432)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Storage bucket name (create this in Supabase Dashboard → Storage)
SUPABASE_STORAGE_BUCKET=report-images

# ─── Redis (Upstash — free tier at https://upstash.com) ──────────────────────
# Console → your database → REST API → copy the "UPSTASH_REDIS_REST_URL" redis URL
# Use the rediss:// (TLS) URL for Upstash
REDIS_URL=rediss://default:[PASSWORD]@[ENDPOINT].upstash.io:6379

# ─── MQTT ─────────────────────────────────────────────────────────────────────
# Provided by the IoT team for production.
# For local dev/testing use the free public HiveMQ broker (no auth needed):
#   MQTT_BROKER_URL=mqtt://broker.hivemq.com:1883
MQTT_BROKER_URL=mqtt://broker.hivemq.com:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret_minimum_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_minimum_32_chars_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Firebase FCM ─────────────────────────────────────────────────────────────
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=

# ─── IoT Sensor Thresholds (env defaults, configurable per water point later) ─
THRESHOLD_WATER_LEVEL_LOW=20
THRESHOLD_WATER_LEVEL_CRITICAL=10
THRESHOLD_PRESSURE_HIGH=5.0
THRESHOLD_PRESSURE_LOW=0.5
THRESHOLD_FLOW_NO_FLOW=0.1
